@model List<Databasefirst.Models.Order>
@{
    Layout = null;
}


<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Order List</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

</head>
<body class="bg-light">

    <div class="container mt-5">

        <h2 class="text-center mb-4">Order List</h2>
        @*&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
        <a href="/Order/AddOrder/" class="btn btn-outline-primary">Add One more order+</a>*@

        <form action="/Order/Index/" method="post">

            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover shadow">

                    <thead class="table-dark text-center">
                        <tr>
                            <th>Order ID</th>
                            <th>Order Item Name</th>
                            <th>Order Date</th>
                            <th>Order Quantity</th>
                            <th>Order Price</th>
                            <th>Order Status</th>
                            <th>Customer Id</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody class="text-center">
                        @{
                            foreach (var m in Model)
                            {
                                <tr>
                                    <td>@m.oid</td>
                                    <td>@m.oname</td>
                                    <td>@m.odate</td>
                                    <td>@m.qty</td>
                                    <td>@m.oprice</td>
                                    <td>@m.ostatus</td>
                                    <td>@m.custID</td>
                                    <td>
                                        <a href="/Order/EditOrder/@m.oid"
                                           class="btn btn-outline-primary">
                                            Edit
                                        </a>
                                        <a href="/Order/DeleteOrder/@m.oid" class="btn btn-outline-warning">Delete</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>

        </form>

    </div>

</body>
</html>