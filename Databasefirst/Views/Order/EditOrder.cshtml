
@model Databasefirst.Models.Order

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Update Order</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #667eea, #764ba2);
            min-height: 100vh;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
        }

        .form-control {
            border-radius: 10px;
        }

        .btn-primary {
            border-radius: 10px;
            width: 100%;
        }

        h3 {
            font-weight: bold;
            text-align: center;
        }
    </style>
</head>

<body>

    <div class="container mt-5 d-flex justify-content-center">
        <div class="card p-4 col-md-6 bg-white">


            <h3 class="mb-4">
                Update Order
                <img src="~/images/cheef.jfif" width="58" height="56" />
            </h3>
            <form method="post" action="@Url.Action("EditOrder","Order")">

                <!-- Row 1 -->
                <div class="row">
                    <input type="hidden" name="oid" value="@Model.oid" />
                    <div class="col-md-6 mb-3">
                        <label>Item Name</label>
                        <input type="text" class="form-control" value="@Model.oname" name="oname" placeholder="Enter Item Name" />
                    </div>


                    <div class="col-md-6 mb-3">
                        <label>Order Date</label>
                        <input type="date" name="odate" value="@Model.odate" class="form-control" />
                    </div>
                </div>

                <!-- Row 2 -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Quantity</label>
                        <input type="number" name="qty" value="@Model.qty" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Price</label>
                        <input type="number" name="oprice" value="@Model.oprice" class="form-control" />
                    </div>
                </div>

                <!-- Row 3 -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Status</label>
                        <input type="text" class="form-control" value="@Model.ostatus" name="ostatus" placeholder="Pending / Delivered" />
                    </div>

                    <div class=" col-md-6 mb-3">
                        <label>Customer ID</label>
                        <input type="number" name="custID" value="@Model.custID" class="form-control" />
                    </div>
                </div>

                <button name="submit"  value="update" class="btn btn-primary mt-3">Update Order</button>

            </form>

        </div>
    </div>

   
</body>
</html>
