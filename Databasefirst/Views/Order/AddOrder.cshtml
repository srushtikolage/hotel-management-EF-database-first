@*@model Databasefirst.Models.Order*@

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Add Order</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(to right, #667eea, #764ba2);
            min-height: 100vh;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
        }

        .form-control {
            border-radius: 10px;
        }

        .btn-primary {
            border-radius: 10px;
            width: 100%;
        }

        h3 {
            font-weight: bold;
            text-align: center;
        }
       
    </style>
</head>

<body>

    <div class="container mt-5 d-flex justify-content-center">
        <div class="card p-4 col-md-6 bg-white">
            

            <h3 class="mb-4">
                Add Order
                <img src="~/images/cheef.jfif" width="58" height="56" />
            </h3>
            <form action="Addorder" method="post">

                <!-- Row 1 -->
                <div class="row">
                    <input type="hidden" id="id" value="" />

                    <div class="col-md-6 mb-3">
                        <label>Item Name</label>
                        <input type="text" class="form-control" name="oname" placeholder="Enter Item Name" />
                    </div>


                    <div class="col-md-6 mb-3">
                        <label>Order Date</label>
                        <input type="date" name="odate" class="form-control" />
                    </div>
                </div>

                <!-- Row 2 -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Quantity</label>
                        <input type="number" name="qty" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Price</label>
                        <input type="number" name="oprice" class="form-control" />
                    </div>
                </div>

                <!-- Row 3 -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label>Status</label>
                        <input type="text" class="form-control" name="ostatus" placeholder="Pending / Delivered" />
                    </div>

                    <div class=" col-md-6 mb-3">
                        <label>Customer ID</label>
                        <input type="number" name="custID" class="form-control" />
                    </div>
                </div>

                <button name="submit"  class="btn btn-primary mt-3">Add Order</button>

            </form>

        </div>
    </div>

    @if (TempData["msg"] != null)
    {
        <script>
        alert('@TempData["msg"]');
        </script>
    }

</body>
</html>

