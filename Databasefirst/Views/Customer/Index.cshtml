@model List<Databasefirst.Models.Customer>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Customer List</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

</head>
<body class="bg-light">

    <div class="container mt-5">

        <h2 class="text-center mb-4">Customer List</h2>

        <form action="/Customer/Index/" method="post">

            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover shadow">

                    <thead class="table-dark text-center">
                        <tr>
                            <th>Customer ID</th>
                            <th>Customer Name</th>
                            <th>Customer Email</th>
                            <th>Customer Phone</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody class="text-center">
                        @{
                            foreach (var x in Model)
                            {
                                <tr>
                                    <td>@x.cid</td>
                                    <td>@x.cname</td>
                                    <td>@x.cemail</td>
                                    <td>@x.cphone</td>
                                    <td>
                                        <a href="/Customer/EditCustomer?id=@x.cid"
                                           class="btn btn-outline-primary">
                                            Edit
                                        </a>
                                        <a href="/Customer/DeleteCustomer/@x.cid" 
                                           class="btn btn-outline-warning">
                                        Delete
                                            </a>|
                                        <a href="/Order/AddOrder?cid=@x.cid"
                                           class="btn btn-outline-success">
                                            Take Order
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>

        </form>

    </div>

</body>
</html>