
@*@{
    Layout = null;
}*@

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>AddCustomer</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />


    <style>
        body {
            background: linear-gradient(to right, #667eea, #764ba2);
            min-height: 100vh;
        }

        .card {
            border-radius: 15px;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
        }

        .form-control {
            border-radius: 10px;
        }

        .btn-primary {
            border-radius: 10px;
            width: 100%;
        }

        h3 {
            font-weight: bold;
            text-align: center;
        }
    </style>
</head>
<body>

   
    <form action="AddCustomer" method="post">
        
        <div class="container mt-5 d-flex justify-content-center">
            <div class="card p-4 col-md-5 bg-white">

                <div class="d-flex align-items-center gap-2">
                    <img src="~/images/customeradd.jfif" class="mb-3" height="50px" width="75px" />
                    <h3 class="mb-0">Add Customer</h3>
                </div>

                <div class="row">

                    <div class="col-md-12 mb-4">

                        <label>Customer Name</label>
                        <input type="text" id="customername" name="cname" class="form-control" placeholder="Enter name" />
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-12 mb-4">

                        <label>Customer Email</label>
                        <input type="email" id="email" name="cemail" class="form-control" placeholder="Enter Email" />

                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-4">
                        <label>Customer Phone No</label>
                        <input type="number" id="number" name="cphone" class="form-control" placeholder="Enter Contact Number" />
                    </div>
                </div>
                <button name="submit" class="btn btn-primary mt-3">Add Customer</button>

            </div>
        </div>
    </form>

</body>
</html>
